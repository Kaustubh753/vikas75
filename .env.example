# ─────────────────────────────────────────────────────────────────────────────
# Vikas 75 — environment variables
# Copy this file to .env.local and fill in the values:  cp .env.example .env.local
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Pusher — REQUIRED ────────────────────────────────────────────────────────
# Real-time sync between phones, host and projector. The server refuses to boot
# without these four (see src/lib/env.ts / src/instrumentation.ts). Create a
# free app at https://dashboard.pusher.com — use the Channels product.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2

# Client-side Pusher config (browser). Mirror the values above; without them the
# server boots but players get no live updates and fall back to a 30 s poll.
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ── Upstash Redis — OPTIONAL (required for production) ────────────────────────
# Room persistence. Without it, rooms live in an in-memory Map: fine for a single
# local dev instance, but NOT shared across serverless instances (so production on
# Vercel needs Redis). Create one at https://console.upstash.com (Redis, REST).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Anthropic — OPTIONAL ─────────────────────────────────────────────────────
# The Claude AI judge. Without it, a random fallback judge with Hinglish verdicts
# is used. https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Admin dashboard — OPTIONAL ───────────────────────────────────────────────
# Basic-auth credentials for /admin and the "End Room" action. If unset, the
# admin dashboard and DELETE /api/game are disabled.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── App URL — OPTIONAL ───────────────────────────────────────────────────────
# Absolute base URL used for OpenGraph/Twitter card metadata. Defaults to the
# production Vercel URL if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
